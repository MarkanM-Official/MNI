# ============================================
# MNI Automation Manager - Environment Variables
# Copy this to .env and fill your values
# ============================================

# --- Admin ---
ADMIN_PASSWORD=admin@123@321
ADMIN_SECRET_KEY=change-this-random-jwt-secret-at-least-32-characters
BOT_SYNC_SECRET=change-this-bot-sync-secret
# Keep this master key outside git in production. It decrypts enc:: values.
MNI_SECRET_KEY=change-this-encryption-master-key
# Backward-compatible fallback. New installs should prefer MNI_SECRET_KEY.
MARKANM_SECRET_KEY=

# --- Flask ---
FLASK_PORT=5000
FLASK_DEBUG=False
BACKEND_URL=http://localhost:5000
CORS_ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120

# --- Claude AI (Primary Text API) ---
ANTHROPIC_API_KEY=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# --- Discord ---
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=

# --- WhatsApp (Meta Business) ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# --- Instagram (Meta Business) ---
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_VERIFY_TOKEN=

# --- Image Generation APIs ---
IMAGE_API_PRIMARY=openai        # openai / stability / replicate
OPENAI_API_KEY=
STABILITY_API_KEY=

# --- Voice Generation APIs ---
VOICE_API_PRIMARY=elevenlabs
ELEVENLABS_API_KEY=

# --- Video Generation APIs ---
VIDEO_API_PRIMARY=replicate
REPLICATE_API_KEY=

# --- Database ---
# Preferred on Render: set a managed Postgres `DATABASE_URL`.
# If unset and a Render disk is attached, the app will store SQLite at `$RENDER_DISK_PATH/keli_ai.db`.
# If neither is present, it falls back to local `instance/keli_ai.db`.
# Admin panel can also save a future external DB URL into `instance/deployment_settings.json`
# for the next restart, but env `DATABASE_URL` still has highest priority.
DATABASE_URL=sqlite:///keli_ai.db

# --- Google Meet OAuth ---
# You can also copy config/google_auth.example.json to config/google_auth.json.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# --- Google Admin Login ---
# Used by the "Login with Google" button. Client ID is public; do not put Client Secret in frontend.
# Allowlist is required so random Google accounts cannot access the admin panel.
GOOGLE_ALLOWED_EMAILS=owner@example.com

# --- n8n Automations ---
N8N_URL=
N8N_API_KEY=
N8N_WEBHOOK_URL=
N8N_TRIGGER_KEYWORD=/workflow

# --- Email / SMTP ---
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM=

# --- Optional Runtime Flags ---
TELEGRAM_ENABLED=true
INSTAGRAM_ENABLED=true
WHATSAPP_ENABLED=true
MODERATION_ENABLED=true
TRUSTED_MEMBER_IDS=
ADMIN_IDENTITIES=
MARKANM_DISABLE_BACKGROUND_WORKERS=false

# --- Keli Core Voice Call Connector ---
KELI_CORE_VOICE_CALL_WEBHOOK=
KELI_CORE_VOICE_CALL_SECRET=

# Secret values can be converted to enc::... using:
# python scripts/encrypt_env.py .env
